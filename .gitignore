# секреты — токены ботов. Репозиторий ПУБЛИЧНЫЙ, поэтому ловим все варианты:
# .env, .env.local, .env.prod… — кроме шаблона без секретов.
config.json
.env
.env.*
!.env.example
# зависимости
node_modules/
# рабочие временные файлы
.tmp/
# выгрузки диагностики Ozon (сырые ответы витрины)
prices/.probe/
prices/data/
# выходные файлы (создаются при работе бота)
загруженные фото/
без фона/
готовые карточки/
обрезка 3-4/

# python cache
__pycache__/
*.pyc
