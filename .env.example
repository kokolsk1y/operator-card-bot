# Скопируй в .env и заполни.

# ── Бот-генератор карточек (сервис bot) ──
# Токен от @BotFather:
BOT_TOKEN=сюда_токен_бота

# ── Бот поиска цен на маркетплейсах (сервис prices) ──
# ОТДЕЛЬНЫЙ бот, заводится у @BotFather заново. Не тот же токен!
PRICES_BOT_TOKEN=сюда_токен_второго_бота

# Кому можно пользоваться, telegram user_id через запятую.
# ПУСТО = открыт всем (данные разделены по владельцу — чужого никто не видит).
# Чтобы закрыть кругом сотрудников — впиши id через запятую (@userinfobot).
PRICES_ALLOWED_USERS=

# Ozon. Включать ТОЛЬКО после успешного прогона:  node prices/probe-ozon.mjs
# с российского IP (на сервере). Пока 0 — работает один Wildberries.
PRICES_OZON_ENABLED=0
