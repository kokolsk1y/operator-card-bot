# Скопируй в .env и заполни.

# ── Бот-генератор карточек (сервис bot) ──
# Токен от @BotFather:
BOT_TOKEN=сюда_токен_бота

# ── Бот мониторинга цен (сервис prices) ──
# ОТДЕЛЬНЫЙ бот, заводится у @BotFather заново. Не тот же токен!
PRICES_BOT_TOKEN=сюда_токен_второго_бота

# Кому можно пользоваться, telegram user_id через запятую.
# БЕЗ ЭТОГО СЕРВИС НЕ СТАРТУЕТ — бот знает закупочные цены компании,
# пускать всех подряд нельзя (в отличие от бота карточек).
# Свой id узнать: написать @userinfobot
PRICES_ALLOWED_USERS=123456789

# Как часто проверять цены по подтверждённым товарам, минут.
# Ошибочные цены живут минуты-часы: та же лампа за час менялась 63 -> 80 руб.
PRICES_CHECK_EVERY_MIN=20

# Как часто искать новых кандидатов, часов. Поиск дорогой: WB отдаёт 429
# уже на 4-м запросе подряд, поэтому редко.
PRICES_SEARCH_EVERY_HOURS=24

# Ozon. Включать ТОЛЬКО после успешного прогона:  node prices/probe-ozon.mjs
# с российского IP. Пока 0 — работает один Wildberries.
PRICES_OZON_ENABLED=0
